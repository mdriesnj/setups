2. Enable PCI Passthru
(Intel)
cp /etc/default/grub /etc/default/grub.orig
vi /etc/default/grub
  GRUB_CMDLINE_LINUX_DEFAULT="quiet intel_iommu=on iommu=pt
update-grub
