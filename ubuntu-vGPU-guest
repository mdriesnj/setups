3.Configure static network
/etc/netplan/99_config.yaml
network:
  version: 2
  renderer: networkd
  ethernets:
    ens18:
      addresses:
        - 10.11.0.1/24
      routes:
        - to: default
          via: 10.11.0.254
      nameservers:
        search: [ digitaldiscord.org ]
        addresses: [ 10.11.0.254 ]
sudo netplan apply


